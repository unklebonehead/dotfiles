{
   "background": {
      "persistent": false,
      "scripts": [ "background.js" ]
   },
   "browser_action": {
      "default_icon": {
         "128": "icons/hivetips.png",
         "16": "icons/hivetips.png",
         "32": "icons/hivetips.png",
         "48": "icons/hivetips.png"
      },
      "default_popup": "popup/popup.html",
      "default_title": "hivetips"
   },
   "content_scripts": [ {
      "js": [ "contentscript/twitter.js" ],
      "matches": [ "https://twitter.com/*" ],
      "run_at": "document_idle"
   }, {
      "js": [ "contentscript/youtube.js" ],
      "matches": [ "https://*.youtube.com/watch*" ],
      "run_at": "document_idle"
   }, {
      "js": [ "contentscript/directtip.js" ],
      "matches": [ "https://twitter.com/*", "https://youtube.com/*", "https://hive.blog/*", "https://peakd.com/*", "https://hiveblocks.com/*" ],
      "run_at": "document_idle"
   }, {
      "js": [ "contentscript/callback.js" ],
      "matches": [ "https://*.fullalt.com/hivetips-callback/*" ],
      "run_at": "document_idle"
   }, {
      "js": [ "contentscript/yt-callback.js" ],
      "matches": [ "https://*.fullalt.com/yt-callback/*" ],
      "run_at": "document_idle"
   }, {
      "js": [ "contentscript/gmail-callback.js" ],
      "matches": [ "https://*.fullalt.com/e-mail-callback/*" ],
      "run_at": "document_idle"
   }, {
      "js": [ "contentscript/hiveblog.js" ],
      "matches": [ "https://hive.blog/*" ],
      "run_at": "document_idle"
   }, {
      "js": [ "contentscript/peakd.js" ],
      "matches": [ "https://peakd.com/*" ],
      "run_at": "document_idle"
   } ],
   "content_security_policy": "script-src 'self' 'unsafe-eval' https://maxcdn.bootstrapcdn.com https://code.jquery.com; object-src 'self'; child-src 'unsafe-eval' 'self'",
   "default_locale": "en",
   "description": "__MSG_description__",
   "icons": {
      "128": "icons/hivetips.png",
      "48": "icons/hivetips.png"
   },
   "key": "",
   "manifest_version": 2,
   "name": "__MSG_hivetips__",
   "permissions": [ "storage", "activeTab", "tabs", "notifications" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.0.4",
   "version_name": "1.0.4 beta",
   "web_accessible_resources": [ "icons/*", "assets/*" ]
}
